{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [
      {
        "name": "deploymentName",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment name",
        "defaultValue": "openclaw",
        "toolTip": "Short name (3-12 chars), lowercase letters and digits only. Used as a prefix for all created resources.",
        "constraints": {
          "required": true,
          "regex": "^[a-z][a-z0-9]{2,11}$",
          "validationMessage": "3-12 characters, lowercase letters and digits, must start with a letter."
        },
        "visible": true
      }
    ],
    "steps": [
      {
        "name": "agentConfig",
        "label": "Agent configuration",
        "elements": [
          {
            "name": "modelProvider",
            "type": "Microsoft.Common.DropDown",
            "label": "Model provider",
            "defaultValue": "Kimi (Moonshot)",
            "toolTip": "Which LLM should the agent route to.",
            "constraints": {
              "allowedValues": [
                { "label": "Kimi (Moonshot)",      "value": "moonshot" },
                { "label": "Anthropic Claude",     "value": "anthropic" },
                { "label": "OpenAI GPT",           "value": "openai" },
                { "label": "Google Gemini",        "value": "google" },
                { "label": "DeepSeek",             "value": "deepseek" },
                { "label": "xAI Grok",             "value": "xai" }
              ],
              "required": true
            }
          },
          {
            "name": "modelApiKey",
            "type": "Microsoft.Common.PasswordBox",
            "label": { "password": "Model API key", "confirmPassword": "Confirm API key" },
            "toolTip": "API key for the chosen provider. Stored on the VM as a 0600 env file.",
            "constraints": { "required": true },
            "options": { "hideConfirmation": false }
          },
          {
            "name": "telegramBotToken",
            "type": "Microsoft.Common.TextBox",
            "label": "Telegram bot token (optional)",
            "defaultValue": "",
            "toolTip": "From BotFather. Leave blank to skip Telegram and add a channel later.",
            "constraints": { "required": false }
          }
        ]
      },
      {
        "name": "vmConfig",
        "label": "VM & access",
        "elements": [
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "VM size",
            "toolTip": "Standard_B2s recommended (2 vCPU / 4 GB RAM).",
            "recommendedSizes": [ "Standard_B2s", "Standard_B2ms", "Standard_D2s_v5" ],
            "constraints": {
              "allowedSizes": [ "Standard_B1ms", "Standard_B2s", "Standard_B2ms", "Standard_D2s_v5" ]
            },
            "options": { "hideDiskTypeFilter": true },
            "osPlatform": "Linux",
            "imageReference": {
              "publisher": "Canonical",
              "offer":     "0001-com-ubuntu-server-jammy",
              "sku":       "22_04-lts-gen2"
            },
            "count": 1
          },
          {
            "name": "adminUsername",
            "type": "Microsoft.Compute.UserNameTextBox",
            "label": "Admin username",
            "defaultValue": "claw",
            "toolTip": "Linux username for SSH.",
            "osPlatform": "Linux",
            "constraints": { "required": true }
          },
          {
            "name": "sshKey",
            "type": "Microsoft.Compute.CredentialsCombo",
            "label": { "authenticationType": "Authentication type", "sshPublicKey": "SSH public key" },
            "toolTip": { "sshPublicKey": "Paste the contents of ~/.ssh/id_rsa.pub or id_ed25519.pub" },
            "constraints": { "required": true, "customPasswordRegex": null },
            "options": { "hideConfirmation": true, "hidePassword": true },
            "osPlatform": "Linux"
          }
        ]
      }
    ],
    "outputs": {
      "deploymentName":   "[basics('deploymentName')]",
      "modelProvider":    "[steps('agentConfig').modelProvider]",
      "modelApiKey":      "[steps('agentConfig').modelApiKey]",
      "telegramBotToken": "[steps('agentConfig').telegramBotToken]",
      "vmSize":           "[steps('vmConfig').vmSize]",
      "adminUsername":    "[steps('vmConfig').adminUsername]",
      "sshPublicKey":     "[steps('vmConfig').sshKey.sshPublicKey]",
      "location":         "[location()]"
    }
  }
}
