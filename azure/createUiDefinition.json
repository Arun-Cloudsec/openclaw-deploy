{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "basics": [
      {
        "name": "deploymentName",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment name",
        "defaultValue": "openclaw",
        "toolTip": "Short name (3-12 chars), lowercase letters and digits only.",
        "constraints": {
          "required": true,
          "regex": "^[a-z][a-z0-9]{2,11}$",
          "validationMessage": "3-12 characters, lowercase letters and digits, must start with a letter."
        }
      }
    ],
    "steps": [
      {
        "name": "agentConfig",
        "label": "Agent configuration",
        "elements": [
          {
            "name": "modelProvider",
            "type": "Microsoft.Common.DropDown",
            "label": "Model provider",
            "defaultValue": "Kimi (Moonshot)",
            "toolTip": "Which LLM should the agent route to.",
            "constraints": {
              "allowedValues": [
                { "label": "Kimi (Moonshot)",  "value": "moonshot" },
                { "label": "Anthropic Claude", "value": "anthropic" },
                { "label": "OpenAI GPT",       "value": "openai" },
                { "label": "Google Gemini",    "value": "google" },
                { "label": "DeepSeek",         "value": "deepseek" },
                { "label": "xAI Grok",         "value": "xai" }
              ],
              "required": true
            }
          },
          {
            "name": "modelApiKey",
            "type": "Microsoft.Common.PasswordBox",
            "label": { "password": "Model API key", "confirmPassword": "Confirm API key" },
            "toolTip": "API key for the chosen provider.",
            "constraints": { "required": true },
            "options": { "hideConfirmation": false }
          },
          {
            "name": "telegramBotToken",
            "type": "Microsoft.Common.TextBox",
            "label": "Telegram bot token (optional)",
            "defaultValue": "",
            "toolTip": "From BotFather. Leave blank to skip Telegram.",
            "constraints": { "required": false }
          }
        ]
      },
      {
        "name": "vmConfig",
        "label": "VM & access",
        "elements": [
          {
            "name": "vmSize",
            "type": "Microsoft.Common.DropDown",
            "label": "VM size",
            "defaultValue": "Standard_B2s (2 vCPU, 4 GB RAM)",
            "toolTip": "B2s recommended. Drop to B1ms for cheaper testing.",
            "constraints": {
              "allowedValues": [
                { "label": "Standard_B1ms (1 vCPU, 2 GB RAM)",  "value": "Standard_B1ms" },
                { "label": "Standard_B2s (2 vCPU, 4 GB RAM)",   "value": "Standard_B2s" },
                { "label": "Standard_B2ms (2 vCPU, 8 GB RAM)",  "value": "Standard_B2ms" },
                { "label": "Standard_D2s_v5 (2 vCPU, 8 GB RAM)","value": "Standard_D2s_v5" }
              ],
              "required": true
            }
          },
          {
            "name": "adminUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Admin username",
            "defaultValue": "claw",
            "toolTip": "Linux username for SSH.",
            "constraints": {
              "required": true,
              "regex": "^[a-z][a-z0-9]{2,30}$",
              "validationMessage": "3-31 chars, lowercase letters/digits, starts with a letter."
            }
          },
          {
            "name": "sshPublicKey",
            "type": "Microsoft.Common.TextBox",
            "label": "SSH public key",
            "defaultValue": "",
            "toolTip": "Paste the full contents of your ~/.ssh/id_rsa.pub or ~/.ssh/id_ed25519.pub",
            "multiLine": true,
            "constraints": {
              "required": true,
              "regex": "^(ssh-rsa|ssh-ed25519|ecdsa-sha2-nistp256|ecdsa-sha2-nistp384|ecdsa-sha2-nistp521)\\s+[A-Za-z0-9+/=]+(\\s+.+)?$",
              "validationMessage": "Must be a valid SSH public key (starts with ssh-rsa or ssh-ed25519)."
            }
          }
        ]
      }
    ],
    "outputs": {
      "deploymentName":   "[basics('deploymentName')]",
      "modelProvider":    "[steps('agentConfig').modelProvider]",
      "modelApiKey":      "[steps('agentConfig').modelApiKey]",
      "telegramBotToken": "[steps('agentConfig').telegramBotToken]",
      "vmSize":           "[steps('vmConfig').vmSize]",
      "adminUsername":    "[steps('vmConfig').adminUsername]",
      "sshPublicKey":     "[steps('vmConfig').sshPublicKey]",
      "location":         "[location()]"
    }
  }
}
